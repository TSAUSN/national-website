<div class="my-5">
  <div>
    <a
      href="#"
      class="return-to-events d-flex gap-2 align-items-center justify-content-start text-decoration-none text-primary-200 return-to-all-events"
    >
      <span class="material-symbols-outlined"> reply </span>
      Return to all events
    </a>
  </div>
  <div class="d-flex align-items-center justify-content-between py-8">
    <h1 class="fs-4">{{ this.title }}</h1>
    <div class="d-flex align-items-center">
      <div class="me-6 d-md-block d-none">
        <span class="display-1 text-dark-50">Share Story</span>
      </div>
      <div>
      {{ include /components/socials-share }}
      </div>
    </div>
  </div>
  <div class="story-card bg-light rounded-5 py-lg-12 px-lg-11 p-sm-4">
    {{if {this.page_layout} == "Image Landscape" }}
    <div class="bg-secondary mb-8">
      <div class="d-flex align-items-center justify-content-center text-white">
        <div class="text-center rounded-3 overflow-hidden ratio ratio-1x1" 
        style="max-height: 738px"
        >
          <img
            class="w-100 h-100 object-fit-cover"
            src="{{ this.image.getImage() }}"
            alt=""
          />
        </div>
      </div>
    </div>
    {{/if}}

    <!-- Metadata -->
    <div class="row">
      {{if {this.page_layout} != "Blank" }}
      <div class="col-md-4 pe-lg-16 pe-sm-1 pb-sm-8 pb-lg-0">
        {{if {this.page_layout} == "Image Thumbnail" }}
        <div class="ratio ratio-4x3 bg-secondary mb-8">
          <div class="text-center rounded-3 overflow-hidden">
            <img
              src="{{ this.image.getImage() }}"
              alt=""
              class="rounded-3"
            />
          </div>
        </div>
        {{else if {this.page_layout} == "No Image" }}
        <div class="position-relative mb-4">
          <div
            class="rounded-5 goggle-map"
            style="height: 384.62px"
          ></div>
          <div class="map-loader d-none">
            <div class="map-loader__spinner"></div>
          </div>
        </div>
        {{/if}}
        <!-- Buttons -->
        {{if {this.page_layout} != "Blank" }}

        <div class="d-flex gap-2">
          {{if {this.primary_cta_name} }}
          <a
            href="{{ this.primary_cta_link }}"
            class="btn btn-info w-100 d-flex align-items-center justify-content-center"
            >{{ this.primary_cta_name }}</a
          >
          {{/if}}
          {{if {this.secondary_cta_name} }}
          <a
            href="{{ this.secondary_cta_link }}"
            class="btn btn-secondary w-100 d-flex align-items-center justify-content-center"
            >{{ this.secondary_cta_name }}</a
          >
          {{/if}}
        </div>
        {{/if}}

        <!-- Date -->
         {{if {this.page_layout} != "Blank" }}
        <div class="pb-4 border-1 border-bottom">
          <div class="my-3 fs-5">Details</div>
          {{if {this.event_date_with_time} || {this.event_end_date_with_time} }}
            <span class="text-dark-50">Date</span>
            <div class="story__date mb-3 fs-6 text-dark-100">
                    
               {{if {this.event_date_with_time} }} {{this.event_date_with_time.date(F j, Y g:i A)}} {{/if}} {{if {this.event_end_date_with_time} }} {{if {this.event_date_with_time} && {this.event_date_with_time.date(Y-m-d)} == {this.event_end_date_with_time.date(Y-m-d)} }} - {{this.event_end_date_with_time.date(g:i A)}} {{else}} {{if {this.event_date_with_time} }} - {{/if}} {{this.event_end_date_with_time.date(F j, Y g:i A)}} {{/if}} {{/if}}
            </div>
          {{else if {this.date_time_summary}  }}
            <span class="text-dark-50">Date & Time</span>
            <div class="story__date mb-3 fs-6 text-dark-100">
                {{this.date_time_summary}}
            </div>
          {{else}}
            <span class="text-dark-50">Date</span>
            <div class="story__date mb-3 fs-6 text-dark-100">
                No specific date
            </div>
          {{/if}}
          <a
            href="https://www.google.com/calendar/render?action=TEMPLATE&text={{this.title}}&dates={{this.date}}&location={{locations.filter({this.parent_zuid}).address }}&sf=true&output=xml"
            class="text-primary-200 text-decoration-none d-flex align-items-center gap-3"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="material-symbols-outlined"> calendar_month </span>
            <span> Add to Calendar </span>
          </a>
        </div>
        {{/if}}

        <!-- Location -->
        {{if {this.page_layout} != "Blank" }}

        <div class="my-4">
          <span class="text-dark-50">Location</span>
          <div class="mb-3 fs-6 text-dark-100 ">
            {{if {this.address} }}{{this.address}}{{/if}}{{if {this.city} }}, <span class="text-capitalize">{{cities.filter({this.city}).title}}</span>{{/if}}{{if {this.state} }}, {{states.filter({this.state}).state_code}}{{/if}}
          </div>
          <a
            href="https://www.google.com/maps?q={{this.address}}, {{this.city}}, {{this.state}}"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary-200 text-decoration-none d-flex align-items-center gap-3"
          >
            <span class="material-symbols-outlined"> location_on </span>
            <span> Directions </span>
          </a>
        </div>
        {{/if}}

        <!-- Map -->
        {{if {this.page_layout} != "No Image" && {this.page_layout} != "Blank" }}
        <div class="position-relative">
          <div
            class="rounded-5 event__map"
            style="height: 384.62px"
          ></div>
          <div class="map-loader d-none">
            <div class="map-loader__spinner"></div>
          </div>
        </div>
        {{/if}}
      </div>
      {{/if}}

      <!-- Content -->
      {{if {this.page_layout} != "Blank" }}
      <div class="col-md-8">
        <div class="border-1 border-bottom pb-4">
          <h4 class="mb-3">About the event</h4>
          {{ this.body }}
        </div>
      {{else}}
      <div class="col-12">
        {{ this.body }}
      </div>
      {{/if}}
        <!-- Contact -->
        {{if {this.page_layout} != "Blank" }}
        <div class="my-4 d-flex align-items-center justify-content-start">
          <div class="d-flex flex-column gap-2">
            <span class="text-dark-50">Contact</span>
            <div>
              <span class="fs-7">{{ this.contact_person_name }}</span>
            </div>
            {{if {this.contact_email} }}
            <div class="text-primary-200 d-flex align-items-center gap-2">
              <span class="material-symbols-outlined"> mail </span>
              <span>
                <a href="mailto:{{this.contact_email}}">
                  {{ this.contact_email }}
                </a>
              </span>
            </div>
            {{/if}}
            {{if {this.contact_number} }}
            <div class="text-primary-200 d-flex align-items-center gap-2">
              <span class="material-symbols-outlined"> call </span>
              <span>{{ this.contact_number }}</span>
            </div>
            {{/if}}
          </div>
        </div>
        {{/if}}
      </div>
      {{if {this.page_layout} != "Blank" }}
      <div class="mt-16">
        {{include modules/upcoming-events}}
      </div>
      {{/if}}
    </div>
  </div>
</div>

<script>

  const returnToAllEvents = document.querySelector(".return-to-all-events")
  
  if (cookieManager.get(cookieKeys.locationModel) == 'NATIONAL') {
    returnToAllEvents.setAttribute("href", "/events")
    
  }else{
    returnToAllEvents.setAttribute("href", getCookieByName("location_home_url")+"events")
      
    }

  function formatDateRange(input) {
    const parts = input.split(" - ");
    if (parts.length === 2) {
            const startDate = new Date(parts[0]);
            const endDate = new Date(parts[1]);
            console.log(startDate, endDate)
            if (endDate < startDate){
              return ""
            }

            return `${parts[0]} - ${parts[1]}`;
    } 
}

  async function getLocation(zuid) {
    try {
      const response = await fetch(`${window.location.origin}/location-finder.json?query=${zuid}`);
      if (!response.ok) {
        throw new Error('Network response was not ok');
      }
      const rawData = await response.text();
      const data = JSON.parse(rawData);
      return data.name;
    } catch (error) {
      console.error('Error checking location:', error);
      return false;
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
      const dateElement = document.querySelector('.story__date'); 
       dateElement.textContent = formatDateRange(dateElement.textContent);
  });


  async function getPageZuid() {
    const model = await fetch(`https://{{instance.domain}}/model-info.json?zuid={{this.zuid}}`);
    const pageData = await model.json();

    if (pageData) {
      return pageData;
    } else {
      return false;
    }
  }
  function getLocationAddress() {
    const address = `{{this.address}},{{this.city}},{{this.state}}`;
    if (address) {
      return address;
    } else {
      return false;
    }
  }
  
  function geocodeEventAddress(address) {
    return new Promise((resolve, reject) => {
        const geocoder = new google.maps.Geocoder();
        if (!geocoder) {
            reject(new Error('Geocoder not initialized'));
            return;
        }

        geocoder.geocode(
            { 
                address: address,
                componentRestrictions: { country: 'US' }
            }, 
            (results, status) => {
                if (status === "OK" && results.length > 0) {
                    const location = results[0].geometry.location;
                    resolve({
                        lat: location.lat(),
                        lng: location.lng()
                    });
                } else {
                    reject(new Error(`Geocoding failed for address: ${address}`));
                }
            }
        );
    });
  }
  async function eventMap() {
    
    const mapStyle = [
      {
          featureType: "water",
          elementType: "geometry",
          stylers: [
              {
                  color: "#e9e9e9",
              },
              {
                  lightness: 17,
              },
          ],
      },
      {
          featureType: "landscape",
          elementType: "geometry",
          stylers: [
              {
                  color: "#f5f5f5",
              },
              {
                  lightness: 20,
              },
          ],
      },
      {
          featureType: "road.highway",
          elementType: "geometry.fill",
          stylers: [
              {
                  color: "#ffffff",
              },
              {
                  lightness: 17,
              },
          ],
      },
      {
          featureType: "road.highway",
          elementType: "geometry.stroke",
          stylers: [
              {
                  color: "#ffffff",
              },
              {
                  lightness: 29,
              },
              {
                  weight: 0.2,
              },
          ],
      },
      {
          featureType: "road.arterial",
          elementType: "geometry",
          stylers: [
              {
                  color: "#ffffff",
              },
              {
                  lightness: 18,
              },
          ],
      },
      {
          featureType: "road.local",
          elementType: "geometry",
          stylers: [
              {
                  color: "#ffffff",
              },
              {
                  lightness: 16,
              },
          ],
      },
      {
          featureType: "poi",
          elementType: "geometry",
          stylers: [
              {
                  color: "#f5f5f5",
              },
              {
                  lightness: 21,
              },
          ],
      },
      {
          featureType: "poi.park",
          elementType: "geometry",
          stylers: [
              {
                  color: "#dedede",
              },
              {
                  lightness: 21,
              },
          ],
      },
      {
          elementType: "labels.text.stroke",
          stylers: [
              {
                  visibility: "on",
              },
              {
                  color: "#ffffff",
              },
              {
                  lightness: 16,
              },
          ],
      },
      {
          elementType: "labels.text.fill",
          stylers: [
              {
                  saturation: 36,
              },
              {
                  color: "#333333",
              },
              {
                  lightness: 40,
              },
          ],
      },
      {
          elementType: "labels.icon",
          stylers: [
              {
                  visibility: "off",
              },
          ],
      },
      {
          featureType: "transit",
          elementType: "geometry",
          stylers: [
              {
                  color: "#f2f2f2",
              },
              {
                  lightness: 19,
              },
          ],
      },
      {
          featureType: "administrative",
          elementType: "geometry.fill",
          stylers: [
              {
                  color: "#fefefe",
              },
              {
                  lightness: 20,
              },
          ],
      },
      {
          featureType: "administrative",
          elementType: "geometry.stroke",
          stylers: [
              {
                  color: "#fefefe",
              },
              {
                  lightness: 17,
              },
              {
                  weight: 1.2,
              },
          ],
      },
    ];
    const eventAddress = await getLocationAddress();
    const coords = await geocodeEventAddress(eventAddress);
    
    // Store the center coordinates
    const mapCenter = { lat: coords.lat, lng: coords.lng };

    window.map = new google.maps.Map(document.querySelector(".event__map"), {
        center: mapCenter,
        zoom: 12,
        mapTypeId: "roadmap",
        fullscreenControl: false,
        mapTypeControl: false,
        streetViewControl: false,
        styles: mapStyle,
    });

    const selectedIcon = {
        url: 'https://8hxvw8tw.media.zestyio.com/location_filled.png',
        origin: new google.maps.Point(0, 0),
        anchor: new google.maps.Point(15, 40),
        scaledSize: new google.maps.Size(40, 40)
    };

    const marker = new google.maps.Marker({
        position: mapCenter,
        map: window.map,
        icon: selectedIcon,
        title: "{{ this.title }}",
        selectedIcon: selectedIcon, // Store selected icon
        defaultIcon: selectedIcon, // Store default icon
    });
  }

  window.eventMap = eventMap;
  getPageZuid();
</script>
