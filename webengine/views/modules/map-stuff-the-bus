  const getRegistryData = async () => {
    try {
      const response = await fetch(`https://api.quickbase.com/v1/records/query`, {
        method: "POST",
        headers: {
          'QB-Realm-Hostname': 'saapps.quickbase.com',
          'Authorization': 'QB-USER-TOKEN ca43nd_mn6f_0_vff9axtcqg3fceraqiic2kasz7',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          "from": "bvxwt6a5d",
          "select": [130, 153, 158, 15, 121, 122, 31, 32, 16, 17, 156, 157, 162, 39, 131, 132, 133, 170, 23, 24, 25, 26, 149, 8, 177, 178, 134, 135, 136, 169, 137, 138, 139, 168],
          "where": "{52.CampaignName.'Stuff the Bus Registry'}"
        })
      });

      const { data } = await response.json();
      console.log("Registry:", data);
      const items = Array.isArray(data) ? data : Object.values(data);
      return items.map(item => ({
        unitID:        item["130"]?.value ?? "",
        divisionCode:  item["158"]?.value ?? "",
        unitName:      item["15"]?.value ?? "",
        address:       item["121"]?.value ?? "",
        city:          item["122"]?.value ?? "",
        state:         item["31"]?.value ?? "",
        registryURL:   item["32"]?.value ?? "",
        division:      item["16"]?.value ?? "",
        territory:     item["17"]?.value ?? "",
        latitude:      parseFloat(item["156"]?.value) || parseFloat(item["177"]?.value) || null,
        longitude:     parseFloat(item["157"]?.value) || parseFloat(item["178"]?.value) || null,
        displayName:   item["162"]?.value ?? "",
        participating: item["39"]?.value ?? "",
        june:   buildMonthSchedule(item["132"]?.value, item["131"]?.value, item["133"]?.value, item["170"]?.value),
        july:   buildMonthSchedule(item["134"]?.value, item["135"]?.value, item["136"]?.value, item["169"]?.value),
        august: buildMonthSchedule(item["137"]?.value, item["138"]?.value, item["139"]?.value, item["168"]?.value),
      }));
    } catch (error) {
      console.log("ERROR Stuff the Bus", error.message);
      return [];
    }
  };

  const buildMonthSchedule = (allDay, morning, afternoon, evening) => {
    const toArr = (v) => Array.isArray(v) ? v : [];
    const ad = toArr(allDay), mo = toArr(morning), af = toArr(afternoon), ev = toArr(evening);
    const dates = [...new Set([...ad, ...mo, ...af, ...ev])];
    return dates.reduce((acc, date) => {
      acc[date] = {
        allDay:    ad.includes(date),
        morning:   mo.includes(date),
        afternoon: af.includes(date),
        evening:   ev.includes(date),
      };
      return acc;
    }, {});
  };

  const getStores = async (data) => {
    // console.log(data);
    const items = Array.isArray(data) ? data : Object.values(data);
    const result = items.map(item => ({
      storeNumer: item["153"].value ?? "",
      locationID: item["130"].value ?? "",
      storeName: item["23"]?.value ?? "",
      storeType:   item["24"]?.value ?? "",
      address:     item["25"]?.value ?? "",
      city:        item["26"]?.value ?? "",
      state:       item["149"]?.value ?? "",
      zip:         item["8"]?.value ?? "",
      latitude:    parseFloat(item["177"]?.value) || null,
      longitude:   parseFloat(item["178"]?.value) || null,
      june:   buildMonthSchedule(item["132"]?.value, item["131"]?.value, item["133"]?.value, item["170"]?.value),
      july:   buildMonthSchedule(item["134"]?.value, item["135"]?.value, item["136"]?.value, item["169"]?.value),
      august: buildMonthSchedule(item["137"]?.value, item["138"]?.value, item["139"]?.value, item["168"]?.value),
    }));
    console.log("Store Results:", result)

    return result;
  }


  const createOptimizedBatchGeocoder = (rateLimitMs = 10) => {
    let geocoder = null;

    const initialize = () => {
      if (window.google && window.google.maps) {
        geocoder = new google.maps.Geocoder();
        return true;
      }
      return false;
    };

    const geocodeWithRateLimit = async (address) => {
      if (!geocoder && !initialize()) throw new Error('Google Maps API not ready');
      return new Promise((resolve) => {
        setTimeout(() => {
          geocoder.geocode({ address }, (results, status) => {
            resolve(
              status === google.maps.GeocoderStatus.OK && results?.length > 0
                ? { lat: results[0].geometry.location.lat(), lng: results[0].geometry.location.lng(), formatted_address: results[0].formatted_address }
                : null
            );
          });
        }, Math.random() * rateLimitMs);
      });
    };

    return { initialize, geocodeWithRateLimit };
  };

  const batchGeocoder = createOptimizedBatchGeocoder();

  const toRadians = (degrees) => degrees * (Math.PI / 180);

  const calculateLocationDistance = (lat1, lon1, lat2, lon2) => {
    const R = 3959;
    const dLat = toRadians(lat2 - lat1);
    const dLon = toRadians(lon2 - lon1);
    const a =
      Math.sin(dLat / 2) ** 2 +
      Math.cos(toRadians(lat1)) * Math.cos(toRadians(lat2)) * Math.sin(dLon / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  };

  const createPinIcon = (color) => {
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40">
      <path d="M20 2C13.37 2 8 7.37 8 14c0 8.75 12 24 12 24s12-15.25 12-24c0-6.63-5.37-12-12-12zm0 16.5c-2.49 0-4.5-2.01-4.5-4.5S17.51 9.5 20 9.5 24.5 11.51 24.5 14 22.49 18.5 20 18.5z" fill="${color}" stroke="#FFFFFF" stroke-width="1"/>
    </svg>`;
    return {
      url: 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(svg),
      origin: new google.maps.Point(0, 0),
      anchor: new google.maps.Point(20, 40),
      scaledSize: new google.maps.Size(40, 40)
    };
  };

  const markerPool = (() => {
    const activeMarkers = [];

    const addMarker = (mapInstance, lat, lng, title, icon, type = '', id = '') => {
      const marker = new google.maps.Marker({ position: { lat, lng }, map: mapInstance, title, icon });
      activeMarkers.push({ marker, type, id });
      return marker;
    };

    const clearAllMarkers = () => {
      activeMarkers.forEach(({ marker }) => marker.setMap(null));
      activeMarkers.length = 0;
    };

    const filterByTypes = (types) => {
      activeMarkers.forEach(({ marker, type: markerType }) => {
        marker.setVisible(types.includes(markerType));
      });
    };

    const showAllMarkers = () => {
      activeMarkers.forEach(({ marker }) => marker.setVisible(true));
    };

    const syncVisibilityFromCards = () => {
      activeMarkers.forEach(({ marker, id }) => {
        const card = id ? document.querySelector(`.stuff-the-bus__item[data-id="${id}"]`) : null;
        if (card) marker.setVisible(!card.classList.contains('d-none'));
      });
    };

    return { addMarker, clearAllMarkers, filterByTypes, showAllMarkers, syncVisibilityFromCards };
  })();

  const filterByRadius = async (stores, locationsRegistry, inputLocation, radiusMiles = 50) => {
    const center = await batchGeocoder.geocodeWithRateLimit(inputLocation);
    if (!center) throw new Error('Could not geocode input location');

    const attachDistance = (items) =>
      items
        .filter((item) => item.latitude && item.longitude)
        .map((item) => ({
          ...item,
          distance: Math.round(calculateLocationDistance(center.lat, center.lng, item.latitude, item.longitude) * 100) / 100
        }))
        .filter((item) => item.distance <= radiusMiles)
        .sort((a, b) => a.distance - b.distance);

    return {
      filteredStores: attachDistance(stores),
      filteredLocationsRegistry: attachDistance(locationsRegistry),
      center
    };
  };

  const formatDropOffTimes = (store) => {
    const timeRanges = { morning: '8AM – 12PM', afternoon: '12PM – 4PM', evening: '4PM – 8PM' };
    const months = [
      { label: 'June',   data: store.june },
      { label: 'July',   data: store.july },
      { label: 'August', data: store.august },
    ];
    const blocks = months.flatMap(({ label, data }) => {
      if (!data || Object.keys(data).length === 0) return [];
      return Object.entries(data).map(([date, slots]) => {
        const dateLabel = `${label} ${date}`;
        if (slots.allDay) {
          return `<div class="mb-1"><p class="text-muted mb-0 display-3 fw-semibold">${dateLabel}</p><p class="text-muted mb-0 display-3 ps-3">Drop off is available all day</p></div>`;
        }
        const slotRows = [
          { slot: 'Morning',   key: 'morning',   time: timeRanges.morning },
          { slot: 'Afternoon', key: 'afternoon',  time: timeRanges.afternoon },
          { slot: 'Evening',   key: 'evening',    time: timeRanges.evening },
        ]
          .filter(t => slots[t.key])
          .map(t => `<p class="text-muted mb-0 display-3 ps-3"><strong>${t.slot}:</strong> ${t.time}</p>`)
          .join('');
        return slotRows ? `<div class="mb-1"><p class="text-muted mb-0 display-3 fw-semibold">${dateLabel}</p>${slotRows}</div>` : '';
      }).filter(Boolean);
    }).join('');
    return blocks ? `<div class="mt-1">${blocks}</div>` : '';
  };

  const extractCardDates = (item) => {
    const year = new Date().getFullYear();
    const monthMap = { june: 5, july: 6, august: 7 };
    return ['june', 'july', 'august'].flatMap(month => {
      const data = item[month];
      if (!data) return [];
      return Object.keys(data).map(day =>
        new Date(year, monthMap[month], parseInt(day)).toISOString().split('T')[0]
      );
    }).join(',');
  };

  const isCardExpired = (dates) => {
    if (!dates) return false;
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    return dates.split(',').every(d => new Date(d.trim()) < today);
  };

  const generateDirectionsLinks = (address, analyticsData) => {
    const encoded = encodeURIComponent(address);
    const analyticsAttrs = analyticsData ? `
      data-link-location-type="body:map"
      data-link-function-type="other"
      data-link-format-type="button"
      data-link-type="external"
      data-location-name="${analyticsData.name}"
      data-location-search-term="${analyticsData.search_term}"
      data-location-search-results="${analyticsData.total_results}"
      data-location-search-type="location search - body"
      data-location-search-method-type="user-entered"
      data-location-search-result-index="${analyticsData.result_index}"
      onclick="LocationTrackingResultsClickEvent(this, 'stuff_the_bus_result_click')"` : '';
    return `<div class="text-muted mb-0 display-3 mt-2">
      <strong>Directions:</strong>
      <a class="text-dark-50 me-2 display-4 display-md-3" href="https://www.google.com/maps/dir/?api=1&destination=${encoded}&travelmode=walking" target="_blank" rel="noopener noreferrer" ${analyticsAttrs}>Walking</a>
      <a class="text-dark-50 me-2 display-4 display-md-3" href="https://www.google.com/maps/dir/?api=1&destination=${encoded}&travelmode=driving" target="_blank" rel="noopener noreferrer" ${analyticsAttrs}>Driving</a>
      <a class="text-dark-50 me-2 display-4 display-md-3" href="https://www.google.com/maps/dir/?api=1&destination=${encoded}&travelmode=transit" target="_blank" rel="noopener noreferrer" ${analyticsAttrs}>Public Transport</a>
    </div>`;
  };

  const downloadStbICS = (name, address, dates) => {
    const now = new Date().toISOString().replace(/[-:.]/g, '').slice(0, 15) + 'Z';
    const events = dates.split(',').map(dateStr => {
      const d = dateStr.trim().replace(/-/g, '');
      return [
        'BEGIN:VEVENT',
        `UID:stb-${d}-${Math.random().toString(36).substr(2, 6)}@stuffthebus`,
        `DTSTAMP:${now}`,
        `DTSTART;VALUE=DATE:${d}`,
        `DTEND;VALUE=DATE:${d}`,
        `SUMMARY:Stuff the Bus Drop-off at ${name}`,
        `LOCATION:${address}`,
        'DESCRIPTION:Drop off school supplies for Stuff the Bus.',
        'END:VEVENT'
      ].join('\r\n');
    }).join('\r\n');
    const ics = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Stuff the Bus//EN','CALSCALE:GREGORIAN','METHOD:PUBLISH', events,'END:VCALENDAR'].join('\r\n');
    const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `stuff-the-bus-${name.replace(/[^a-z0-9]/gi, '-').toLowerCase()}.ics`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  };

  const generateResultCards = (filteredStores, filteredLocationsRegistry, analyticsObject) => {
    const storeCards = filteredStores.map((store, i) => {
      const dates = extractCardDates(store);
      const fullAddress = [store.address, store.city, store.state].filter(Boolean).join(', ');
      const expired = isCardExpired(dates);
      const safeName = (store.storeType || 'Walmart Store').replace(/'/g, "\\'");
      const safeAddr = fullAddress.replace(/'/g, "\\'");
      return `<div class="stuff-the-bus__item card mb-2 mt-2 border rounded${expired ? ' opacity-50' : ''}" data-id="store-${i}" data-type="store"${dates ? ` data-dates="${dates}"` : ''}>
        <div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-1">
            <span class="badge bg-secondary-100">Store</span>
            ${expired ? '<span class="badge bg-secondary">Event Passed</span>' : ''}
          </div>
          <h5 class="card-title fw-bold text-secondary-200 mb-1 display-2">${store.storeType || 'Walmart Store'}</h5>
          <p class="text-muted mb-0 display-3">${fullAddress}</p>
          <p class="text-muted mb-0 display-3">${store.distance} mi away</p>
          <div class="mt-2">
            ${formatDropOffTimes(store)}
          </div>
          <div class="mt-8 border-top pt-4">
            ${generateDirectionsLinks(fullAddress, { name: store.storeName || store.storeType || 'Walmart Store', search_term: analyticsObject.search_term, total_results: analyticsObject.total_results, result_index: i })}
          </div>
          <div class="mt-2">
            ${dates && !expired ? `<button class="btn btn-sm btn-secondary d-flex align-items-center gap-1 mt-2" onclick="downloadStbICS('${safeName}', '${safeAddr}', '${dates}')"><span class="material-symbols-outlined display-2">calendar_add_on</span> Add to Calendar</button>` : ''}  
          </div>
        </div>
      </div>`;
    }).join('');

    const registryCards = filteredLocationsRegistry.map((loc, i) => {
      const dates = extractCardDates(loc);
      const fullAddress = [loc.address, loc.city, loc.state].filter(Boolean).join(', ');
      const expired = isCardExpired(dates);
      const safeName = (loc.displayName || loc.unitName || 'Location').replace(/'/g, "\\'");
      const safeAddr = fullAddress.replace(/'/g, "\\'");
      return `<div class="stuff-the-bus__item card mb-2 mt-2 border rounded${expired ? ' opacity-50' : ''}" data-id="registry-${i}" data-type="online"${dates ? ` data-dates="${dates}"` : ''}>
        <div class="card-body">
          <div class="d-flex align-items-center gap-2 mb-1">
            <span class="badge bg-success">Online Participating</span>
            ${expired ? '<span class="badge bg-secondary">Event Passed</span>' : ''}
          </div>
          <h5 class="card-title fw-bold text-secondary-200 mb-1 display-2">${loc.displayName || loc.unitName || 'Location'}</h5>
          <p class="text-muted mb-0 display-3">${fullAddress}</p>
          <p class="text-muted mb-0 display-3">${loc.distance} mi away</p>
          ${loc.registryURL ? `<a
            href="${loc.registryURL}"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm mt-2 bg-success text-white"
            data-link-location-type="body:map"
            data-link-function-type="other"
            data-link-format-type="button"
            data-link-type="external"
            data-location-name="${loc.displayName || loc.unitName || 'Location'}"
            data-location-search-term="${analyticsObject.search_term}"
            data-location-search-results="${analyticsObject.total_results}"
            data-location-search-type="location search - body"
            data-location-search-method-type="user-entered"
            data-location-search-result-index="${i}"
            onclick="LocationTrackingResultsClickEvent(this, 'stuff_the_bus_result_click')"
          >Register Online</a>` : ''}
          ${dates && !expired ? `<button class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1 mt-2" onclick="downloadStbICS('${safeName}', '${safeAddr}', '${dates}')"><span class="material-symbols-outlined display-2">calendar_add_on</span> Add to Calendar</button>` : ''}
        </div>
      </div>`;
    }).join('');

    return storeCards + registryCards;
  };


  const setupFilterBar = () => {
    const buttons = document.querySelectorAll('#stb-filterbar button[data-filter]');

    const activeColorMap = {
      store:  'bg-secondary-100',
      online: 'bg-success'
    };

    const dotOriginalColorMap = {
      store:  'bg-secondary-100',
      online: 'bg-success'
    };

    buttons.forEach(btn => {
      btn.addEventListener('click', function () {
        const filter = this.dataset.filter;
        const isActive = this.classList.contains('active');

        if (isActive) {
          this.classList.remove(activeColorMap[filter], 'text-white', 'active');
          this.classList.add('border');
          const dot = this.querySelector('span.d-block');
          if (dot) {
            dot.classList.remove('bg-white');
            dot.classList.add(dotOriginalColorMap[filter]);
          }
        } else {
          this.classList.add(activeColorMap[filter], 'text-white', 'active');
          this.classList.remove('border');
          const dot = this.querySelector('span.d-block');
          if (dot) {
            dot.classList.remove(dotOriginalColorMap[filter]);
            dot.classList.add('bg-white');
          }
        }

        const activeFilters = [...buttons]
          .filter(b => b.classList.contains('active'))
          .map(b => b.dataset.filter);

        const cards = document.querySelectorAll('.stuff-the-bus__item');

        if (activeFilters.length === 0) {
          cards.forEach(c => c.classList.remove('d-none'));
          markerPool.showAllMarkers();
        } else {
          cards.forEach(c => c.classList.toggle('d-none', !activeFilters.includes(c.dataset.type)));
          markerPool.filterByTypes(activeFilters);
        }
      });
    });
  };

  const setupDateRangePicker = () => {
    const startInput = document.getElementById('stb-date-start');
    const endInput   = document.getElementById('stb-date-end');
    const clearBtn   = document.getElementById('stb-date-clear');
    if (!startInput || !endInput) return;

    // if (!document.getElementById('stb-datepicker-fix')) {
    //   const style = document.createElement('style');
    //   style.id = 'stb-datepicker-fix';
    //   document.head.appendChild(style);
    // }

    const year    = new Date().getFullYear();
    const minDate = new Date(year, 5, 1);   // June 1
    const maxDate = new Date(year, 7, 31);  // August 31

    const sharedOptions = {
      format: 'M d, yyyy',
      autohide: true,
      minDate,
      maxDate,
      updateOnBlur: false,
      todayHighlight: true,
    };

    const startPicker = new Datepicker(startInput, { ...sharedOptions });
    const endPicker   = new Datepicker(endInput,   { ...sharedOptions });

    const applyDateFilter = () => {
      const start = startPicker.getDate();
      const end   = endPicker.getDate();

      if (start) endPicker.setOptions({ minDate: start });
      if (end)   startPicker.setOptions({ maxDate: end });

      if (!start && !end) return;

      const toDateStr = (d) => {
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${y}-${m}-${day}`;
      };
      const startStr = start ? toDateStr(start) : null;
      const endStr   = end   ? toDateStr(end)   : null;

      document.querySelectorAll('.stuff-the-bus__item').forEach(card => {
        const rawDates = card.dataset.dates;
        if (!rawDates) { card.classList.add('d-none'); return; }
        const inRange = rawDates.split(',').some(d => {
          const ds = d.trim();
          return (!startStr || ds >= startStr) && (!endStr || ds <= endStr);
        });
        card.classList.toggle('d-none', !inRange);
      });
      markerPool.syncVisibilityFromCards();
    };

    startInput.addEventListener('changeDate', applyDateFilter);
    endInput.addEventListener('changeDate', applyDateFilter);

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        startPicker.setDate({ clear: true });
        endPicker.setDate({ clear: true });
        startPicker.setOptions({ maxDate });
        endPicker.setOptions({ minDate });
        document.querySelectorAll('.stuff-the-bus__item').forEach(c => c.classList.remove('d-none'));
        markerPool.showAllMarkers();
      });
    }
  };

  const searchStuffTheBusLocations = async () => {
    const input = document.querySelector('#stuff-the-bus__input');
    const loader = document.querySelector('.map-loader');
    const cardsContainer = document.querySelector('#stuff-the-bus-result');
    const mapContentContainer = document.querySelector('#stuff-the-bus-content');
    const inputValue = input?.value?.trim();

    if (!inputValue) return;

    cardsContainer.classList.remove('d-none');
    cardsContainer.setAttribute('style', 'height: 400px; max-height: 400px;');
    const filterbar = document.querySelector('#stb-filterbar');
    if (filterbar) filterbar.classList.add('d-none');
    if (mapContentContainer) mapContentContainer.classList.add('d-none');
    if (loader) loader.classList.remove('d-none');

    markerPool.clearAllMarkers();

    const dotResetMap = { store: 'bg-secondary-100', online: 'bg-success' };
    document.querySelectorAll('#stb-filterbar button[data-filter]').forEach(b => {
      b.classList.remove('bg-secondary-100', 'bg-success', 'text-white', 'active');
      b.classList.add('border');
      const dot = b.querySelector('span.d-block');
      if (dot) {
        dot.classList.remove('bg-white');
        dot.classList.add(dotResetMap[b.dataset.filter]);
      }
    });

    try {
      const { filteredStores, filteredLocationsRegistry, center } = await filterByRadius(allStores, allLocationsRegistry, inputValue);

      const storeIcon = createPinIcon('#77a9ee');
      const locationRegistryIcon = createPinIcon('#12825F');

      const total = filteredStores.length + filteredLocationsRegistry.length;
      const analyticsObject = {
        search_term: inputValue,
        total_results: total
      };

      filteredStores.forEach((store, i) => {
        const marker = markerPool.addMarker(map, store.latitude, store.longitude, store.storeName || 'Store', storeIcon, 'store', `store-${i}`);
        marker.addListener('click', function() {
          const searchInfo = {
            searchTerm: inputValue,
            totalResults: total,
            searchMethod: 'user-entered',
            filterType: 'stuff_the_bus',
            filterValue: 'store'
          };
          const locationData = {
            resultIndex: i,
            location_id: store.locationID || '',
            name: store.storeName || store.storeType || 'Store',
            location_org_detail: ''
          };
          LocationTrackingMapClickEvent(locationData, searchInfo, 'stuff_the_bus_map_click');
        });
      });

      filteredLocationsRegistry.forEach((loc, i) => {
        const marker = markerPool.addMarker(map, loc.latitude, loc.longitude, loc.displayName || loc.unitName || 'Location', locationRegistryIcon, 'online', `registry-${i}`);
        marker.addListener('click', function() {
          const searchInfo = {
            searchTerm: inputValue,
            totalResults: total,
            searchMethod: 'user-entered',
            filterType: 'stuff_the_bus',
            filterValue: 'online'
          };
          const locationData = {
            resultIndex: i,
            location_id: loc.unitID || '',
            name: loc.displayName || loc.unitName || 'Location',
            location_org_detail: `SAL^${loc.unitID || ''}`
          };
          LocationTrackingMapClickEvent(locationData, searchInfo, 'stuff_the_bus_map_click');
        });
      });

      map.setZoom(10);
      map.setCenter(center);

      cardsContainer.innerHTML = total > 0
        ? generateResultCards(filteredStores, filteredLocationsRegistry, analyticsObject)
        : '<p class="p-3 text-muted text-center">No results found.</p>';
      if (filterbar) {
        filterbar.classList.toggle('d-none', total === 0);
        const countStore = document.querySelector('#stb-count-store');
        const countOnline = document.querySelector('#stb-count-online');
        if (countStore) countStore.textContent = filteredStores.length;
        if (countOnline) countOnline.textContent = filteredLocationsRegistry.length;
      }

      if (total > 0) {
        input.setAttribute('data-search-term-type', inputValue);
        input.setAttribute('data-search-filter-type', 'stuff_the_bus');
        input.setAttribute('data-search-results-type', total);
        input.setAttribute('data-search-method-type', 'user-entered');
        input.setAttribute('data-search-type-type', 'location search - body');
        LocationTrackingSearchEvent(input, 'stuff_the_bus_search');
      }
    } catch (error) {
      console.error('Search error:', error);
      cardsContainer.innerHTML = '<p class="p-3">Error occurred during search. Please try again.</p>';
      if (filterbar) filterbar.classList.add('d-none');
    } finally {
      if (loader) loader.classList.add('d-none');
    }
  };

  function stuffTheBusInputAddressSuggestion() {
    const input = document.querySelector('#stuff-the-bus__input');
    if (!input) return;

    let sessionToken = new google.maps.places.AutocompleteSessionToken();
    const autocompleteService = new google.maps.places.AutocompleteService();
    let debounceTimer;

    const autocompleteContainer = document.createElement('div');
    autocompleteContainer.className = 'autocomplete-dropdown-container-stb';
    autocompleteContainer.style.cssText = `
      position: absolute; z-index: 1050; background: white;
      border: 1px solid #d1d5db; border-radius: 8px;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
      max-height: 280px; overflow-y: auto; display: none; width: 100%; margin-top: 4px;
    `;

    if (!document.getElementById('autocomplete-styles-stb')) {
      const style = document.createElement('style');
      style.id = 'autocomplete-styles-stb';
      style.textContent = `
        .autocomplete-item-stb { padding: 12px 16px; cursor: pointer; border-bottom: 1px solid #f3f4f6; display: flex; align-items: center; gap: 10px; }
        .autocomplete-item-stb:last-child { border-bottom: none; }
        .autocomplete-item-stb:hover { background-color: #f9fafb; }
        .autocomplete-text-stb { color: #1f2937; font-size: 14px; }
      `;
      document.head.appendChild(style);
    }

    input.parentNode.style.position = 'relative';
    input.parentNode.appendChild(autocompleteContainer);

    input.addEventListener('input', function () {
      const value = this.value;
      clearTimeout(debounceTimer);
      if (value.length < 3) { autocompleteContainer.style.display = 'none'; return; }

      debounceTimer = setTimeout(() => {
        autocompleteService.getPlacePredictions(
          { input: value, types: ['(regions)'], componentRestrictions: { country: 'US' }, sessionToken },
          (predictions, status) => {
            if (status === google.maps.places.PlacesServiceStatus.OK && predictions) {
              autocompleteContainer.innerHTML = '';
              autocompleteContainer.style.display = 'block';
              predictions.forEach((prediction) => {
                const item = document.createElement('div');
                item.className = 'autocomplete-item-stb';
                item.innerHTML = `
                  <svg width="18" height="18" fill="none" stroke="#6b7280" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <span class="autocomplete-text-stb">${prediction.description}</span>
                `;
                item.addEventListener('click', function () {
                  input.value = prediction.description;
                  autocompleteContainer.style.display = 'none';
                  sessionToken = new google.maps.places.AutocompleteSessionToken();
                });
                autocompleteContainer.appendChild(item);
              });
            } else {
              autocompleteContainer.style.display = 'none';
            }
          }
        );
      }, 300);
    });

    document.addEventListener('click', function (e) {
      if (e.target !== input && !autocompleteContainer.contains(e.target)) {
        autocompleteContainer.style.display = 'none';
      }
    });
  }

  const handleUseMyLocation = async () => {
    const button = document.querySelector('.use-my-location-stuff');
    const input = document.querySelector('#stuff-the-bus__input');
    const loader = document.querySelector('.map-loader');

    if (button) {
      button.disabled = true;
      button.innerHTML = `<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Getting Location...`;
    }
    if (loader) loader.classList.remove('d-none');

    try {
      if (!navigator.geolocation) throw new Error('Geolocation is not supported by this browser.');

      const position = await new Promise((resolve, reject) => {
        navigator.geolocation.getCurrentPosition(resolve, reject, { enableHighAccuracy: true, timeout: 10000, maximumAge: 300000 });
      });

      const { latitude, longitude } = position.coords;
      const geocoder = new google.maps.Geocoder();
      const geocodeResult = await new Promise((resolve, reject) => {
        geocoder.geocode({ location: { lat: latitude, lng: longitude } }, (results, status) => {
          status === google.maps.GeocoderStatus.OK && results?.length > 0
            ? resolve(results[0])
            : reject(new Error('Unable to get address from coordinates'));
        });
      });

      if (input) {
        input.value = geocodeResult.formatted_address;
        input.dispatchEvent(new Event('input', { bubbles: true }));
      }

      await new Promise((resolve) => setTimeout(resolve, 100));
      await searchStuffTheBusLocations();
    } catch (error) {
      console.error('Error getting location:', error);
      let msg = 'Unable to get your location. ';
      if (error.code === 1) msg += 'Location access was denied.';
      else if (error.code === 2) msg += 'Location information is unavailable.';
      else if (error.code === 3) msg += 'Location request timed out.';
      else msg += error.message || 'Please try again.';
      alert(msg);
    } finally {
      if (button) {
        button.disabled = false;
        button.innerHTML = `<span class="material-symbols-outlined me-2">my_location</span> Use My Location`;
      }
      if (loader) loader.classList.add('d-none');
    }
  };

  window.addEventListener('mapReady', async (event) => {
    map = event.detail.map;
    if (!map) return;

    const submitBtn = document.querySelector('#stuff-the-bus__search-btn');
    const loader = document.querySelector('.map-loader');
    if (loader) loader.classList.remove('d-none');

    try {
      if (!batchGeocoder.initialize()) throw new Error('Failed to initialize geocoder');

      const response = await getData();
      allStores = await getStores(response);
      allLocationsRegistry = await getRegistryData();

      if (submitBtn) submitBtn.removeAttribute('disabled');
      stuffTheBusInputAddressSuggestion();
      setupFilterBar();
      setupDateRangePicker();

      const useLocationButton = document.querySelector('.use-my-location-stuff');
      if (useLocationButton) {
        useLocationButton.removeEventListener('click', handleUseMyLocation);
        useLocationButton.addEventListener('click', handleUseMyLocation);
      }
    } catch (error) {
      console.error('Stuff the Bus map initialization error:', error);
    } finally {
      if (loader) loader.classList.add('d-none');
    }
  });

</script>