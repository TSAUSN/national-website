<div class="d-flex flex-sm-column flex-lg-row bg-light row rounded-5 w-100 m-auto mb-16" id="ATonline">
  <div class="col-sm-12 col-lg-5 p-sm-4 p-lg-7">
    <div>
      {{if {!this.map_heading} }}
      <div class="mb-8">
        <h3 class="fs-5">{{this.map_heading}}</h3>
        <div id="stuff-the-bus-content" class="container mt-8 px-0">
          {{if {!this.map_content} }}
            {{this.map_content}}
          {{/if}}
        </div>
      </div>
      {{/if}}
      <div class="input-group mb-6">
        <input
          type="text"
          class="form-control"
          placeholder="Enter your city or Zip Code"
          aria-label="Enter your city or Zip Code"
          id="stuff-the-bus__input"
          data-search-term-type=""
          data-search-results-type=""
          data-search-type="location search - body"
          data-search-method-type="user-entered"
          data-search-filter-type="Services"
          data-search-filter-value-type=""
          onkeydown="if(event.key === 'Enter') { searchStuffTheBusLocations(); event.preventDefault(); }"
        >
      </div>
      <div class="d-flex">
        {{this.map_filter_instructions}}
      </div>
      <div class="d-flex">
        <button id="stuff-the-bus__search-btn" class="btn btn-primary w-75" onclick="searchStuffTheBusLocations()" disabled>
          Search Location
        </button>
        <button class="btn btn-outline-danger w-50 d-flex align-items-center justify-content-end text-primary-200 display-1 use-my-location-stuff ">
          <span class="material-symbols-outlined me-2">
            my_location
          </span> Use My Location
        </button>
      </div>
      <div class="d-none d-flex align-items-center flex-wrap gap-2 border-top pt-6 mt-6" id="stb-filterbar">
        <span class="text-secondary fw-semibold text-uppercase me-1 display-4">Filter</span>
        <button class="btn btn-sm border rounded d-flex align-items-center gap-2 px-3 py-1" data-filter="store">
          <span class="stuff__filter rounded flex-shrink-0 bg-secondary-100 d-block"></span>
          In store drop off
          <span class="text-secondary ms-1 display-4" id="stb-count-store">0</span>
        </button>
        <button class="btn btn-sm border rounded d-flex align-items-center gap-2 px-3 py-1" data-filter="online">
          <span class="stuff__filter rounded flex-shrink-0 bg-success d-block"></span>
          Online Registry
          <span class="text-secondary ms-1 display-4" id="stb-count-online">0</span>
        </button>
        <div class="d-md-flex align-items-center justify-content-center gap-2 w-100 mt-2 pt-6 border-top" id="stb-date-range-filter">
          <span class="d-flex text-secondary fw-semibold text-uppercase me-1 mb-4 mb-md-0 display-4">Date Range</span>
          <div class="d-md-flex align-items-center gap-1 flex-shrink-0">
            <div class="position-relative">
              <input
                type="text"
                id="stb-date-start"
                class="stuff__datepicker form-control form-control-sm rounded pointer"
                placeholder="Start date"
                readonly
              >
            </div>
            <span class="text-secondary px-1"></span>
            <div class="position-relative">
              <input
                type="text"
                id="stb-date-end"
                class="stuff__datepicker form-control form-control-sm rounded pointer"
                placeholder="End date"
                readonly
              >
            </div>
          </div>
          <button class="btn btn-sm btn-primary d-flex align-items-center mt-4 mt-md-0" id="stb-date-clear" title="Clear date filter">
            <span class="display-4">Reset</span>
          </button>
        </div>
      </div>
    </div>
    <div>
      <div id="stuff-the-bus-result" class="container d-flex flex-column mt-4 overflow-auto mb-2 pt-2 d-none"></div>
    </div>
    
  </div>
  <div class="col-sm-12 col-lg-7 p-sm-4 p-lg-7">
    <div class="col-12 p-0 order-sm-1 order-lg-2 position-relative">
      <div class="rounded-5 goggle-map"></div>
      <div class="map-loader d-none">
        <div class="map-loader__spinner"></div>
      </div>
    </div>
  </div>
</div>

<script>
  let map = null;
  let allStores = [];
  let allLocationsRegistry = [];

  // Data fetching (unchanged)
  const getData = async () => {
    try {
      const response = await fetch(`https://api.quickbase.com/v1/records/query`, {
        method: "POST",
        headers: {
