											},
											"content:textarea:13:23": {
												"icon": "align-justify",
												"name": "Paragraph",
												"type": "textarea",
												"html": "<p>\n\t\t\t\t\tThe Community Care Ministry Program is an expression of love in the best traditions of The Salvation Army’s service and it truly reflects the ideal of giving hearts to God and hands to man. Men, women and young people spend time making personal visits and conducting services to cheer lonely and sick people across the nation. Whether it be patients in hospitals (including Veterans Administration Medical Center), nursing homes and institutions, or others unable to care for themselves (shut-ins, disabled, blind), the Community Care Ministry volunteer provides warm, personal attention and often times the patients only link to the outside world.\n\t\t\t\t</p>",
												"description": "Mixed Plain and Rich Text",
												"draggable": true,
												"content": "The Community Care Ministry Program is an expression of love in the best traditions of The Salvation Army’s service and it truly reflects the ideal of giving hearts to God and hands to man. Men, women and young people spend time making personal visits and conducting services to cheer lonely and sick people across the nation. Whether it be patients in hospitals (including Veterans Administration Medical Center), nursing homes and institutions, or others unable to care for themselves (shut-ins, disabled, blind), the Community Care Ministry volunteer provides warm, personal attention and often times the patients only link to the outside world.",
												"position": 10,
												"fullName": "content:textarea:13:23",
												"htmlElement": "p",
												"primarytype": "content",
												"id": "content:textarea:13:23",
												"styles": {},
												"newLoc": "design:columns:2columns:25:46-1:2 Columns - Equal:0",
												"oldLoc": "bank",
												"contentOverride": false
											},
											"content:textarea:14:74": {
												"icon": "align-justify",
												"name": "Paragraph",
												"type": "textarea",
												"html": "<p>\n\t\t\t\t\tDuring the Christmas Season, volunteers of the Community Care Ministry program deliver thousands of gifts to those who must spend their holidays confined to bed or far away from loved ones.\n\t\t\t\t</p>",
												"description": "Mixed Plain and Rich Text",
												"draggable": true,
												"content": "During the Christmas Season, volunteers of the Community Care Ministry program deliver thousands of gifts to those who must spend their holidays confined to bed or far away from loved ones.",
