											"content:textarea:9:35": {
												"icon": "align-justify",
												"name": "Paragraph",
												"type": "textarea",
												"html": "<p>\n\t\t\t\t\tScrapbooking is an exciting new addition to the Women’s Ministries program. It provides an opportunity for community women to share ideas, resources and Christian fellowship as they work to creatively preserve their photographs. A highlight of the scrapbooking program has been&nbsp;Camp-Crop-A-Lot, an entire weekend at Camp Tomahawk of scrabooking time, classes, games, workshops and Christian fellowship.\n\t\t\t\t</p>",
												"description": "Mixed Plain and Rich Text",
												"draggable": true,
												"content": "Scrapbooking is an exciting new addition to the Women’s Ministries program. It provides an opportunity for community women to share ideas, resources and Christian fellowship as they work to creatively preserve their photographs. A highlight of the scrapbooking program has been&nbsp;Camp-Crop-A-Lot, an entire weekend at Camp Tomahawk of scrabooking time, classes, games, workshops and Christian fellowship.",
