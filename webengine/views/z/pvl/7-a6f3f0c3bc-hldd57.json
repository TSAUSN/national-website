											"content:textarea:11:39": {
												"icon": "align-justify",
												"name": "Paragraph",
												"type": "textarea",
												"html": "<p>\n\t\t\t\t\tThe Men’s Fellowship Club aims to provide men with the skills essential for a happy, wholesome, godly home life and a personal experience of salvation through Jesus Christ. Through sports, outings, and educational endeavors the program offers an opportunity for building friendships, participating in Christian fellowship and developing a spirit of camaraderie. Members are encourage to take in interest in their communities with club community service projects and through support of the humanitarian efforts of The Salvation Army and other community organizations.\n\t\t\t\t</p>",
												"description": "Mixed Plain and Rich Text",
												"draggable": true,
												"content": "The Men’s Fellowship Club aims to provide men with the skills essential for a happy, wholesome, godly home life and a personal experience of salvation through Jesus Christ. Through sports, outings, and educational endeavors the program offers an opportunity for building friendships, participating in Christian fellowship and developing a spirit of camaraderie. Members are encourage to take in interest in their communities with club community service projects and through support of the humanitarian efforts of The Salvation Army and other community organizations.",
