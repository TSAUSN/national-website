							"content:wysiwyg_basic:15:93": {
								"icon": "outdent",
								"name": "WYSIWYG",
								"type": "wysiwyg_basic",
								"html": "<div style=\"position:relative;overflow:hidden;min-height:420px;background-image:url('https://s3.amazonaws.com/uss-cache.salvationarmy.org/5a8dfe3a-3801-48ff-8ca9-802e75151be2_177723_DSC_6520+copy.jpg');background-position:center center;background-repeat:no-repeat;background-size:cover;\" class=\"testimonialbox-section text-white rounded\">\n  <div class=\"bg-photo-overlay bg-opacity-60\" style=\"position:absolute;inset:0;z-index:1;\"></div>\n  <div style=\"position:relative;z-index:2;display:flex;align-items:center;justify-content:center;min-height:420px;padding:48px 40px;\">\n    <div style=\"max-width:720px;text-align:center;\">\n      <h6 style=\"text-align:center;\">Providing Future Hope</h6>\n      <p style=\"text-align:center;color:#fff;\">Jennifer lost her job during the height of COVID-19. She began suffering from anxiety and felt as though she had no hope for the future. After reaching out to The Salvation Army of Central Oklahoma, she met one-on-one with a case manager. \"I was able to determine what I was good at and developed a plan to move forward\" said Jennifer. \"Yes I received rental assistance, but I also received hope for my future.\" She now works as a teacher in Oklahoma City and was recently named Teacher of the Month.</p>\n    </div>\n  </div>\n</div>\n<div class=\"py-5\"></div>",
								"description": "Text with HTML references.",
								"draggable": true,
								"content": "<div class=\"testimonialbox-section text-white rounded\" style=\"position:relative;overflow:hidden;min-height:420px;background-image:url('https://s3.amazonaws.com/uss-cache.salvationarmy.org/5a8dfe3a-3801-48ff-8ca9-802e75151be2_177723_DSC_6520+copy.jpg');background-position:center center;background-repeat:no-repeat;background-size:cover;\">\n  <div class=\"bg-photo-overlay bg-opacity-60\" style=\"position:absolute;inset:0;z-index:1;\"></div>\n  <div style=\"position:relative;z-index:2;display:flex;align-items:center;justify-content:center;min-height:420px;padding:48px 40px;\">\n    <div style=\"max-width:720px;text-align:center;\">\n      <h6 style=\"text-align:center;\">Providing Future Hope</h6>\n      <p style=\"text-align:center;color:#fff;\">Jennifer lost her job during the height of COVID-19. She began suffering from anxiety and felt as though she had no hope for the future. After reaching out to The Salvation Army of Central Oklahoma, she met one-on-one with a case manager. \"I was able to determine what I was good at and developed a plan to move forward\" said Jennifer. \"Yes I received rental assistance, but I also received hope for my future.\" She now works as a teacher in Oklahoma City and was recently named Teacher of the Month.</p>\n    </div>\n  </div>\n</div>\n<div class=\"py-5\"></div>",
