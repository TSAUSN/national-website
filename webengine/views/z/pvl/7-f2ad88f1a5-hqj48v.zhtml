<div class="row my-3" data-zesty-id="design:columns:2columns:128:97">
<div class="col-md-6 col-sm-12" data-zesty-id="design:columns:2columns:128:97-1:2 Columns - Equal:0">
<p data-zesty-id="content:textarea:127:89">
					TOTAL RAISED
				</p>
				</div>
<div class="col-md-6 col-sm-12" data-zesty-id="design:columns:2columns:128:97-1:2 Columns - Equal:1">
