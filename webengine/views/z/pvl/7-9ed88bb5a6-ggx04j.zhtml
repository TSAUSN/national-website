	<div data-zesty-id="content:block:6-bcfbdaa6d3-vjj3qs:27:19:0:71">{{block('/-/block/hero_full.html?variant=7-daf4b0d8c8-7n8dmn')}}</div>
	<div class="p-6 rounded-5 bg-light mb-18" data-zesty-id="design:columns:1 column - 1 row my-3:17:76">
