	<div data-zesty-id="content:block:6-bcfbdaa6d3-vjj3qs:27:82:0:83">{{block('/-/block/hero_full.html?variant=7-eed7a89ae3-g7pxz6')}}</div>
	<div class="p-6 rounded-5 bg-light mb-18" data-zesty-id="design:columns:1 column - 1 row my-3:32:26">
