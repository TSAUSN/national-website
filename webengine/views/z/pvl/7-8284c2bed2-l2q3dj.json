							"design:design:whitespace-xl:6:12": {
								"uid": "354",
								"name": "Whitespace - Extra Large",
								"type": "design",
								"classes": "py-5",
								"html": "<div class=\"py-5\"></div>",
								"preview": "<div style=\"border-style:dashed; height:50px; width:100%;\"></div>",
								"droppable": false,
								"position": 4,
								"fullName": "design:design:whitespace-xl:6:12",
