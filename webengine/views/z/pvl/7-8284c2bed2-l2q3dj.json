							"content:textarea:5:91": {
								"icon": "align-justify",
								"name": "Paragraph",
								"type": "textarea",
								"html": "<p class=\"MsoBodyText3\" style=\"text-align:center;\">\n\t<span><span lang=\"en-US\">Majors Karla and Ricky Perez&nbsp;arrived in Hickory June of 2024.&nbsp;&nbsp;</span></span>\n</p>",
								"description": "Mixed Plain and Rich Text",
								"draggable": true,
								"content": "Majors Karla and Ricky Perez&nbsp;arrived in Hickory June of 2024.&nbsp;&nbsp;",
								"position": 3,
								"fullName": "content:textarea:5:91",
