							"content:wysiwyg_basic:12:79": {
								"icon": "outdent",
								"name": "WYSIWYG",
								"type": "wysiwyg_basic",
								"html": "<div class=\"rounded p-6 gap-3 mt-3 bg-dark-100 text-light\" style=\"color:#FFFFFF;\"><div class=\"btgrid\">\n\t<div class=\"row row-1\">\n\t\t<div class=\"col col-md-6\">\n\t\t\t<div class=\"content\">\n\t\t\t\t<h2><span style=\"color:#ffffff;\">Need Prayer?</span></h2>\n\n\t\t\t\t<p>\n\t\t\t\t\t<span style=\"color:#ffffff;\">The Salvation Army of Greater Charlotte wants to lift you and your family up in prayer, during uncertain times. Do you have an urgent need for prayer? Please submit your prayer requests and know that we will pray for you consistently during this time.</span>\n\t\t\t\t</p>\n\n\t\t\t\t<p class=\"cta-button-group d-flex flex-wrap gap-2 my-3 justify-content-start\"><a href=\"mailto:salvationarmycharlotte@uss.salvationarmy.org\" class=\"btn btn-light gap-1 mt-2\">Submit Your Prayer Request</a></p>\n\t\t\t</div>\n\t\t</div>\n\n\t\t<div class=\"col col-md-6\">\n\t\t\t<div class=\"content\">\n\t\t\t\t<h2><span style=\"color:#ffffff;\">The Salvation Army Sunday Services Online</span></h2>\n\n\t\t\t\t<p>\n\t\t\t\t\t<span style=\"color:#ffffff;\">Can't make it to church, or you're still social distancing? You can watch Sunday services from our Temple Community Worship Center, in the comfort of your own home.</span>\n\t\t\t\t</p>\n\n\t\t\t\t<p class=\"cta-button-group d-flex flex-wrap gap-2 my-3 justify-content-start\"><a href=\"https://www.facebook.com/TheSalvationArmyCharlotteTempleCorps\" class=\"btn btn-light gap-1 mt-2\">Watch A Service Online</a></p>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</div>\n\n<p>\n\t&nbsp;\n</p></div>",
								"content": "<div class=\"rounded p-6 gap-3 mt-3 bg-dark-100 text-light\" style=\"color:#FFFFFF;\"><div class=\"btgrid\">\n\t<div class=\"row row-1\">\n\t\t<div class=\"col col-md-6\">\n\t\t\t<div class=\"content\">\n\t\t\t\t<h2><span style=\"color:#ffffff;\">Need Prayer?</span></h2>\n\n\t\t\t\t<p>\n\t\t\t\t\t<span style=\"color:#ffffff;\">The Salvation Army of Greater Charlotte wants to lift you and your family up in prayer, during uncertain times. Do you have an urgent need for prayer? Please submit your prayer requests and know that we will pray for you consistently during this time.</span>\n\t\t\t\t</p>\n\n\t\t\t\t<p class=\"cta-button-group d-flex flex-wrap gap-2 my-3 justify-content-start\"><a href=\"mailto:salvationarmycharlotte@uss.salvationarmy.org\" class=\"btn btn-light gap-1 mt-2\">Submit Your Prayer Request</a></p>\n\t\t\t</div>\n\t\t</div>\n\n\t\t<div class=\"col col-md-6\">\n\t\t\t<div class=\"content\">\n\t\t\t\t<h2><span style=\"color:#ffffff;\">The Salvation Army Sunday Services Online</span></h2>\n\n\t\t\t\t<p>\n\t\t\t\t\t<span style=\"color:#ffffff;\">Can't make it to church, or you're still social distancing? You can watch Sunday services from our Temple Community Worship Center, in the comfort of your own home.</span>\n\t\t\t\t</p>\n\n\t\t\t\t<p class=\"cta-button-group d-flex flex-wrap gap-2 my-3 justify-content-start\"><a href=\"https://www.facebook.com/TheSalvationArmyCharlotteTempleCorps\" class=\"btn btn-light gap-1 mt-2\">Watch A Service Online</a></p>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</div>\n\n<p>\n\t&nbsp;\n</p></div>",
