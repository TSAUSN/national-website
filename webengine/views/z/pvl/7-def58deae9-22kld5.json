			"content:text:1:73": {
				"icon": "text-height",
				"name": "Heading",
				"type": "text",
				"html": "<h5 style=\"text-align:center;\">The Salvation Army of Pickens Red Kettle Ring Off</h5>",
				"description": "Plain Text",
				"draggable": true,
				"content": "The Salvation Army of Pickens Red Kettle Ring Off",
				"position": 1,
				"fullName": "content:text:1:73",
				"htmlElement": "h5",
				"primarytype": "content",
				"id": "content:text:1:73",
				"styles": {
					"textAlign": "center"
				},
				"newLoc": "layout:root:column:0",
				"oldLoc": "bank",
				"contentOverride": false
			},
			"content:textarea:2:53": {
				"icon": "align-justify",
				"name": "Paragraph",
				"type": "textarea",
				"html": "<p>\n\tThe Red Kettle Ring Off is a competition between participating Pickens County Schools. Each year, the schools team up with The Salvation Army of Pickens County to ring the bell outside a store location to raise money for The Salvation Army. The funds raised are used in our “Diversion Program” designed to prevent homelessness in Pickens County.&nbsp;\n</p>",
				"description": "Mixed Plain and Rich Text",
				"draggable": true,
				"content": "The Red Kettle Ring Off is a competition between participating Pickens County Schools. Each year, the schools team up with The Salvation Army of Pickens County to ring the bell outside a store location to raise money for The Salvation Army. The funds raised are used in our “Diversion Program” designed to prevent homelessness in Pickens County.&nbsp;",
				"position": 2,
				"fullName": "content:textarea:2:53",
				"htmlElement": "p",
				"primarytype": "content",
				"id": "content:textarea:2:53",
				"styles": {},
				"newLoc": "layout:root:column:0",
				"oldLoc": "bank",
				"contentOverride": false
			},
			"content:textarea:3:82": {
				"icon": "align-justify",
				"name": "Paragraph",
				"type": "textarea",
				"html": "<p>\n\tIn an effort to expand the competition and raise more funds for our neighbors in need, you can volunteer to ring at any of our eight&nbsp;locations from November 14 to&nbsp;December 24. The funds each group&nbsp;raises will be added to the school’s total amount.&nbsp;On Saturday, December 6, each school will have volunteers at one of 23 special locations. The community is encouraged to come out and support their favorite school!\n</p>",
				"description": "Mixed Plain and Rich Text",
				"draggable": true,
				"content": "In an effort to expand the competition and raise more funds for our neighbors in need, you can volunteer to ring at any of our eight&nbsp;locations from November 14 to&nbsp;December 24. The funds each group&nbsp;raises will be added to the school’s total amount.&nbsp;On Saturday, December 6, each school will have volunteers at one of 23 special locations. The community is encouraged to come out and support their favorite school!",
				"position": 3,
				"fullName": "content:textarea:3:82",
				"htmlElement": "p",
				"primarytype": "content",
				"id": "content:textarea:3:82",
				"styles": {},
				"newLoc": "layout:root:column:0",
				"oldLoc": "bank",
				"contentOverride": false
			},
			"content:textarea:4:66": {
				"icon": "align-justify",
				"name": "Paragraph",
				"type": "textarea",
				"html": "<p>\n\tThe school with the most funds raised from November 14&nbsp;to&nbsp;December 24&nbsp;is deemed the 2025 Red Kettle Ring Off Champion!&nbsp;\n</p>",
				"description": "Mixed Plain and Rich Text",
				"draggable": true,
				"content": "The school with the most funds raised from November 14&nbsp;to&nbsp;December 24&nbsp;is deemed the 2025 Red Kettle Ring Off Champion!&nbsp;",
