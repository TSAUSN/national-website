			"content:wysiwyg_basic:19:39": {
				"icon": "outdent",
				"name": "WYSIWYG",
				"type": "wysiwyg_basic",
				"html": "<ol>\n\t<li>Visit <a href=\"https://registertoring.com\" target=\"\">RegisterToRing.com</a></li>\n\t<li><p>\n\t\tClick “FIND A GROUP” to link to your school and to find available shifts\n\t</p>\n\t</li>\n\t<li><p>\n\t\tEnter the zip code for your school location\n\t</p>\n\t</li>\n\t<li><p>\n\t\tYour school should show up. Click on your Group highlighted in blue\n\t</p>\n\t</li>\n\t<li><p>\n\t\tEnter the dates you want to search for and select the “city” and “location” you want\n\t</p>\n\t</li>\n\t<li><p>\n\t\tClick on the location you want\n\t</p>\n\t</li>\n\t<li><p>\n\t\tClick on the shift you want\n\t</p>\n\t</li>\n\t<li><p>\n\t\tYou will be prompted to sign in or create an account\n\t</p>\n\t</li>\n\t<li><p>\n\t\tClick on “FINISH”\n\t</p>\n\t</li>\n</ol>",
				"description": "Text with HTML references.",
				"draggable": true,
				"content": "<ol>\n\t<li>Visit <a href=\"https://registertoring.com\" target=\"\">RegisterToRing.com</a></li>\n\t<li><p>\n\t\tClick “FIND A GROUP” to link to your school and to find available shifts\n\t</p>\n\t</li>\n\t<li><p>\n\t\tEnter the zip code for your school location\n\t</p>\n\t</li>\n\t<li><p>\n\t\tYour school should show up. Click on your Group highlighted in blue\n\t</p>\n\t</li>\n\t<li><p>\n\t\tEnter the dates you want to search for and select the “city” and “location” you want\n\t</p>\n\t</li>\n\t<li><p>\n\t\tClick on the location you want\n\t</p>\n\t</li>\n\t<li><p>\n\t\tClick on the shift you want\n\t</p>\n\t</li>\n\t<li><p>\n\t\tYou will be prompted to sign in or create an account\n\t</p>\n\t</li>\n\t<li><p>\n\t\tClick on “FINISH”\n\t</p>\n\t</li>\n</ol>",
				"position": 19,
				"fullName": "content:wysiwyg_basic:19:39",
				"htmlElement": "html",
				"primarytype": "content",
				"id": "content:wysiwyg_basic:19:39",
