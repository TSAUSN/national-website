<!-- Live Streams Javascript -->
<p>
<script>
      document.addEventListener("DOMContentLoaded", function () {
        const thumbnails = document.querySelectorAll(".comm25-thumbnail");
        const mainVideo = document.getElementById("comm25-main-video");

        thumbnails.forEach((thumb) => {
          thumb.addEventListener("click", () => {
            const videoId = thumb.getAttribute("data-video-id");
            mainVideo.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;

            // Update active thumbnail
            thumbnails.forEach((t) => t.classList.remove("comm25-active"));
            thumb.classList.add("comm25-active");
          });
        });

        // Set the first as active initially
        if (thumbnails[0]) {
          thumbnails[0].classList.add("comm25-active");
        }
      });
    </script>
</p>
<!-- Carousel Script -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
      // Generate indicators dynamically
      const carousel = document.querySelector('#carouselExampleCaptions');
      if (!carousel) return;
      const indicators = carousel.querySelector('.carousel-indicators');
      const items = carousel.querySelectorAll('.carousel-inner .carousel-item');
      if (!indicators || !items.length) return;
      indicators.innerHTML = '';
      items.forEach((_, index) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.setAttribute('data-bs-target', '#carouselExampleCaptions');
        button.setAttribute('data-bs-slide-to', index);
        button.setAttribute('aria-label', `Slide ${index + 1}`);
        if (index === 0) {
          button.classList.add('active');
          button.setAttribute('aria-current', 'true');
        }
        indicators.appendChild(button);
      });
    });
  </script>
<!-- End of Carousel Script -->
<p></p>
<!-- Cadet Session Expand All Button Script -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
      const toggleButton = document.getElementById("toggleAllBios");
      const checkboxes = document.querySelectorAll(".comm25-toggle");
      let expanded = false;

      toggleButton.addEventListener("click", function () {
        expanded = !expanded;

        checkboxes.forEach((cb) => {
          cb.checked = expanded;
          // Also manually update aria-expanded for accessibility
          const label = document.querySelector(`label[for="${cb.id}"]`);
          if (label) {
            label.setAttribute("aria-expanded", expanded.toString());
          }
        });

        toggleButton.textContent = expanded ? "Collapse All" : "Expand All";
      });
    });
  </script>
<!-- End of Cadet Session Script -->
</div>
