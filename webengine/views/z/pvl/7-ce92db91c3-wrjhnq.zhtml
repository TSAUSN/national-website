<!-- Modern Modal/Lightbox for Gallery -->
<div id="comm26-lightbox"><button id="comm26-close" aria-label="Close gallery">✕</button> <button id="comm26-prev" aria-label="Previous image">‹</button> <img id="comm26-lightbox-img" alt="Gallery image"> <button id="comm26-next" aria-label="Next image">›</button></div>
<script>
            // Modern gallery modal/carousel JS for masonry gallery
            (function () {
              const items = Array.from(document.querySelectorAll('.gallery-modern-masonry .gallery-modern-item img'));
              const lightbox = document.getElementById('comm26-lightbox');
              const lightboxImg = document.getElementById('comm26-lightbox-img');
              const closeBtn = document.getElementById('comm26-close');
              const prevBtn = document.getElementById('comm26-prev');
              const nextBtn = document.getElementById('comm26-next');
              let currentIndex = 0;
              function openLightbox(index) {
                currentIndex = index;
                lightboxImg.src = items[index].src;
                lightbox.classList.add('active');
                lightboxImg.focus();
              }
              function closeLightbox() {
                lightbox.classList.remove('active');
                lightboxImg.src = '';
              }
              function showNext() {
                currentIndex = (currentIndex + 1) % items.length;
                lightboxImg.src = items[currentIndex].src;
              }
              function showPrev() {
                currentIndex = (currentIndex - 1 + items.length) % items.length;
                lightboxImg.src = items[currentIndex].src;
              }
              items.forEach((img, index) => {
                img.addEventListener('click', () => openLightbox(index));
                img.style.cursor = 'pointer';
              });
              closeBtn.addEventListener('click', closeLightbox);
              nextBtn.addEventListener('click', showNext);
              prevBtn.addEventListener('click', showPrev);
              lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
              document.addEventListener('keydown', e => {
                if (!lightbox.classList.contains('active')) return;
                if (e.key === 'Escape') closeLightbox();
                if (e.key === 'ArrowRight') showNext();
                if (e.key === 'ArrowLeft') showPrev();
              });
            })();
          </script>
</div>
<!-- CSS moved to commissioning-weekend-26-m.css --> <!-- Lightbox ...existing code... -->
<div id="comm26-lightbox"><button id="comm26-close2" aria-label="Close gallery">✕</button> <button id="comm26-prev2" aria-label="Previous image">‹</button> <img id="comm26-lightbox-img2" alt="Gallery image"> <button id="comm26-next2" aria-label="Next image">›</button></div>
<script>
          // Modern gallery modal/carousel JS
          (function () {
            const items = Array.from(document.querySelectorAll('.comm26-scroll-item img'));
            const lightbox = document.getElementById('comm26-lightbox');
            const lightboxImg = document.getElementById('comm26-lightbox-img2');
            const closeBtn = document.getElementById('comm26-close2');
            const prevBtn = document.getElementById('comm26-prev2');
            const nextBtn = document.getElementById('comm26-next2');
            let currentIndex = 0;
            function openLightbox(index) {
              currentIndex = index;
              lightboxImg.src = items[index].src;
              lightbox.classList.add('active');
              lightboxImg.focus();
            }
            function closeLightbox() {
              lightbox.classList.remove('active');
              lightboxImg.src = '';
            }
            function showNext() {
              currentIndex = (currentIndex + 1) % items.length;
              lightboxImg.src = items[currentIndex].src;
            }
            function showPrev() {
              currentIndex = (currentIndex - 1 + items.length) % items.length;
              lightboxImg.src = items[currentIndex].src;
            }
            items.forEach((img, index) => {
              img.addEventListener('click', () => openLightbox(index));
              img.style.cursor = 'pointer';
            });
            closeBtn.addEventListener('click', closeLightbox);
            nextBtn.addEventListener('click', showNext);
            prevBtn.addEventListener('click', showPrev);
            lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
            document.addEventListener('keydown', e => {
              if (!lightbox.classList.contains('active')) return;
              if (e.key === 'Escape') closeLightbox();
              if (e.key === 'ArrowRight') showNext();
              if (e.key === 'ArrowLeft') showPrev();
            });
          })();
        </script>
</div>
