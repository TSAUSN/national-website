columnswideright:19:91-4:2 Columns - Left Small:1":{"width":"4","html":"<div class=\"col-md-8 col-sm-12\">*</div>","classes":"col-md-8 col-sm-12","droppable":true,"children":{"content:text:7:6":{"icon":"text-height","name":"Heading","type":"text","html":"<h6>we need your help</h6>","description":"Plain Text","draggable":true,"content":"we need your help","position":0,"fullName":"content:text:7:6","htmlElement":"h4","primarytype":"content","id":"content:text:7:6","styles":{},"newLoc":"design:columns:2columnswideright:19:91-4:2 Columns - Left Small:1","oldLoc":"bank","contentOverride":false},"content:textarea:8:65":{"icon":"align-justify","name":"Paragraph","type":"textarea","html":"<p style=\"text-align:justify;\">\n        Did you know that <span style=\"color:#ed1c2b;\"><strong>1 in 5&nbsp;kids will go to bed hungry</strong> tonight or that <span style=\"color:#ed1c2b;\"><b>1 in 13 seniors have to choose between life-saving medication and food</b></span>? </span>\n      </p>","description":"Mixed Plain and Rich Text","draggable":true,"content":"Did you know that 1 in 5&nbsp;kids will go to bed hungry tonight or that 1 in 13 seniors have to choose between life-saving medication and food?","position":1,"fullName":"content:textarea:8:65","htmlElement":"p","primarytype":"content","id":"content:textarea:8:65","styles":{"textAlign":"justify","fontWeight":"700"},"newLoc":"design:columns:2columnswideright:19:91-4:2 Columns - Left Small:1","oldLoc":"bank","contentOverride":false},"content:textarea:9:64":{"icon":"align-justify","name":"Paragraph","type":"textarea","html":"<p style=\"text-align:justify;\">\n        And did you know that <span style=\"color:#ed1c2b;\"><b>2,700 individuals</b> in the Atlanta area won't have a warm, safe place to sleep tonight?</span>\n      </p>","description":"Mixed Plain and Rich Text","draggable":true,"content":"And did you know that 2,700 individuals in the Atlanta area won't have a warm, safe place to sleep tonight?","position":2,"fullName":"content:textarea:9:64","htmlElement":"p","primarytype":"content","id":"content:textarea:9:64","styles":{"textAlign":"justify","fontWeight":"700"},"newLoc":"design:columns:2columnswideright:19:91-4:2 Columns - Left Small:1","oldLoc":"bank","contentOverride":false},"content:textarea:10:75":{"icon":"align-justify","name":"Paragraph","type":"textarea","html":"<p style=\"text-align:justify;\">\n        These are challenges many of our neighbors face every single day. They are real people with real struggles that threaten their families, threaten their health, threaten their hope that things will ever get better.\n      </p>","description":"Mixed Plain and Rich Text","draggable":true,"content":"These are challenges many of our neighbors face every single day. They are real people with real struggles that threaten their families, threaten their health, threaten their hope that things will ever get better.","position":3,"fullName":"content:textarea:10:75","htmlElement":"p","primarytype":"content","id":"content:textarea:10:75","styles":{"textAlign":"justify"},"newLoc":"design:columns:2columnswideright:19:91-4:2 Columns - Left Small:1","oldLoc":"bank","contentOverride":false},"content:textarea:11:23":{"icon":"align-justify","name":"Paragraph","type":"textarea","html":"<p style=\"text-align:justify;\">\n        <span style=\"color:#ed1c2b;\"><b>With your support, The Salvation Army of Metro Atlanta will meet these needs throughout metro Atlanta.</b></span>\n      </p>","description":"Mixed Plain and Rich Text","draggable":true,"content":"With your support, The Salvation Army of Metro Atlanta will meet these needs throughout metro Atlanta.","position":4,"fullName":"content:textarea:11:23","htmlElement":"p","primarytype":"content","id":"content:textarea:11:23","styles":{"textAlign":"justify","fontWeight":"700"},"newLoc":"design:columns:2columnswideright:19:91-4:2 Columns - Left Small:1","oldLoc":"bank","contentOverride":false},"content:textarea:12:35":{"icon":"align-justify","name":"Paragraph","type":"textarea","html":"<p>\n        Ring The Bell ATL, and join us in our fight to bring aid, comfort and hope to those who need it!\n      </p>","description":"Mixed Plain and Rich Text","draggable":true,"content":"Ring The Bell ATL, and join us in our fight to bring aid, comfort and hope to those who need it!","position":5,"fullName":"content:textarea:12:35","htmlElement":"p","primarytype":"content","id":"content:textarea:12:35","styles":{},"newLoc":"design:columns:2columnswideright:19:91-4:2 Columns - Left Small:1","oldLoc":"bank","contentOverride":false},"content:textarea:13:85":{"icon":"align-justify","name":"Paragraph","type":"textarea","html":"<p style=\"text-align:justify;\">\n        One gift can save one person... many can save many.\n      </p>","description":"Mixed Plain and Rich Text","draggable":true,"content":"One gift can save one person... many can save many.","position":6,"fullName":"content:textarea:13:85","htmlElement":"p","primarytype":"content","id":"content:textarea:13:85","styles":{"textAlign":"justify"},"newLoc":"design:columns:2columnswideright:19:91-4:2 Columns - Left Small:1","oldLoc":"bank","contentOverride":false},"content:wysiwyg_basic:14:79":{"icon":"outdent","name":"WYSIWYG","type":"wysiwyg_basic","html":"<p>\n        <a href=\"https://give.salvationarmygeorgia.org/give/618818/#!/donation/checkout\"><span class=\"btn btn-solid btn-red\">Ring the Bell</span></a>\n      </p>","description":"Text with HTML references.","draggable":true,"content":"<p>\n        <a href=\"https://give.salvationarmygeorgia.org/give/618818/#!/donation/checkout\"><span class=\"btn btn-solid btn-red\">Ring the Bell</span></a>\n      </p>","model":"6","position":7,"fullName":"content:wysiwyg_basic:14:79","htmlElement":"html","primarytype":"content","id":"content:wysiwyg_basic:14:79","styles":{},"newLoc":"design:columns:2columnswideright:19:91-4:2 Columns - Left Small:1","oldLoc":"bank","contentOverride":false},"content:text:16:18":{"icon":