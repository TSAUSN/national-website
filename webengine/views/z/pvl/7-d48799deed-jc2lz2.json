							"content:wysiwyg_basic:11:49": {
								"icon": "outdent",
								"name": "WYSIWYG",
								"type": "wysiwyg_basic",
								"html": "<ul>\n\t<li><strong>In-person:</strong> Adopt an Angel from the Angel Tree at The Outlet Shops of Grand River or The Riverchase Galleria November 7 through December 3, 2025.</li>\n\t<li><strong>Online: </strong>Adopt Angels online by clicking <a href=\"https://www.tsamm.org/angeltree/adopt.dpi?c=4481F46BC05E466E32DA99F86F7AE526592B72DF\" target=\"_blank\">here</a>.&nbsp;Online adoptions will begin November 7. For more information, contact Regina Williams at <a href=\"mailto:Regina.Williams@uss.SalvationArmy.org\" target=\"\">Regina.Williams@uss.SalvationArmy.org</a> .</li>\n\t<li><strong>Forgotten Angels: </strong>Drop-off new, unwrapped toys or gifts at any participating area Chick-fil-A locations, November 7 – December 3, 2025.</li>\n\t<li><strong>Walmart Registry:</strong> Shop our Walmart Registry to purchase gifts online for Angels. Look for ‘2025 Angel Tree program Greater Birmingham Registry', and purchase from the “Wish List” for a child for Christmas. Purchases will be shipped to The Birmingham Area Command and given to a child in need for Christmas. The online registry runs October 24 - December 16, 2025. For more information, contact Regina Williams at&nbsp;<a href=\"mailto:Regina.Williams@uss.SalvationArmy.org\" target=\"\">Regina.Williams@uss.SalvationArmy.org</a> or <a href=\"tel:+12054530947\" target=\"\">205-453-0947</a>.&nbsp;&nbsp;Visit the Birmingham Area Command’s Registry <a href=\"https://www.walmart.com/registry/RR/1b6bbf36-e2e9-410a-b87c-1175c15fe57e\" target=\"_blank\">HERE</a>.</li>\n\t<li><strong>Give Financially:</strong> Bring Christmas wishes to life, by supporting a child or family for the holidays. Make a financial donation at <a href=\"https://southernusa.salvationarmy.org/birmingham-al/waystogive\" target=\"\">BirminghamSalvationArmy.org</a> and click the “<a href=\"https://southernusa.salvationarmy.org/birmingham-al/waystogive\" target=\"\">Ways to Give</a>” tab.&nbsp;</li>\n\t<li><strong>Serve with Us:</strong> Volunteers are the Army behind The Army, and are an important part of #DoingTheMostGood this holiday season.&nbsp; If you or your organization would like to volunteer with us, click&nbsp;<a href=\"https://bttr.im/dp910\" target=\"\">here</a>&nbsp;for more information.</li>\n</ul>",
								"description": "Text with HTML references.",
								"draggable": true,
								"content": "<ul>\n\t<li><strong>In-person:</strong> Adopt an Angel from the Angel Tree at The Outlet Shops of Grand River or The Riverchase Galleria November 7 through December 3, 2025.</li>\n\t<li><strong>Online: </strong>Adopt Angels online by clicking <a href=\"https://www.tsamm.org/angeltree/adopt.dpi?c=4481F46BC05E466E32DA99F86F7AE526592B72DF\" target=\"_blank\">here</a>.&nbsp;Online adoptions will begin November 7. For more information, contact Regina Williams at <a href=\"mailto:Regina.Williams@uss.SalvationArmy.org\" target=\"\">Regina.Williams@uss.SalvationArmy.org</a> .</li>\n\t<li><strong>Forgotten Angels: </strong>Drop-off new, unwrapped toys or gifts at any participating area Chick-fil-A locations, November 7 – December 3, 2025.</li>\n\t<li><strong>Walmart Registry:</strong> Shop our Walmart Registry to purchase gifts online for Angels. Look for ‘2025 Angel Tree program Greater Birmingham Registry', and purchase from the “Wish List” for a child for Christmas. Purchases will be shipped to The Birmingham Area Command and given to a child in need for Christmas. The online registry runs October 24 - December 16, 2025. For more information, contact Regina Williams at&nbsp;<a href=\"mailto:Regina.Williams@uss.SalvationArmy.org\" target=\"\">Regina.Williams@uss.SalvationArmy.org</a> or <a href=\"tel:+12054530947\" target=\"\">205-453-0947</a>.&nbsp;&nbsp;Visit the Birmingham Area Command’s Registry <a href=\"https://www.walmart.com/registry/RR/1b6bbf36-e2e9-410a-b87c-1175c15fe57e\" target=\"_blank\">HERE</a>.</li>\n\t<li><strong>Give Financially:</strong> Bring Christmas wishes to life, by supporting a child or family for the holidays. Make a financial donation at <a href=\"https://southernusa.salvationarmy.org/birmingham-al/waystogive\" target=\"\">BirminghamSalvationArmy.org</a> and click the “<a href=\"https://southernusa.salvationarmy.org/birmingham-al/waystogive\" target=\"\">Ways to Give</a>” tab.&nbsp;</li>\n\t<li><strong>Serve with Us:</strong> Volunteers are the Army behind The Army, and are an important part of #DoingTheMostGood this holiday season.&nbsp; If you or your organization would like to volunteer with us, click&nbsp;<a href=\"https://bttr.im/dp910\" target=\"\">here</a>&nbsp;for more information.</li>\n</ul>",
