							"content:textarea:4:48": {
								"icon": "align-justify",
								"name": "Paragraph",
								"type": "textarea",
								"html": "<p>\n\tTargeting families with children came from the desire to have an intergenerational impact on poverty. By positively influencing the lives of parents, The Salvation Army can create better living conditions for children. Influencing children in their development years is crucial, as studies show that children who spend more than half of their life in poverty are 32 times more likely to be in poverty as an adult.\n</p>",
								"description": "Mixed Plain and Rich Text",
