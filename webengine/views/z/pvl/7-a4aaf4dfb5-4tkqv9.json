        <div class=\"service-content\">\n            <h3>Economic Supports | Hennepin County</h3>\n        </div>\n    </div>\n\n</div>\n\n    </section>\n    \n</body>\n</html>","position":2,"fullName":"content:textarea:1780507296824:0.7578727457016623-copy-1780509450915","htmlElement":"iframe","styles":{},"primarytype":"content","newLoc":"layout:root:column:0","oldLoc":"layout:root:column:0","classes":"services-wrapper","id":"content:textarea:1780507296824:0.7578727457016623-copy-1780509450915","manualContent":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n\n<style>\n\nbody{\n    font-family: Arial, sans-serif;\n    background:#f5f5f5;\n    margin:0;\n    padding:0;\n}\n\n.services-wrapper{\n    position:relative;\n    max-width:1200px;\n    margin:auto;\n}\n\n.services-title{\n    font-size:48px;\n    margin-bottom:25px;\n    color:#222;\n}\n\n/* SCROLL CONTAINER */\n.services-container{\n    display:flex;\n    gap:20px;\n    overflow-x:auto;\n    scroll-behavior:smooth;\n    padding-bottom:10px;\n\n    /* snap effect */\n    scroll-snap-type:x mandatory;\n\n    /* hide scrollbar */\n    scrollbar-width:none;\n}\n\n.services-container::-webkit-scrollbar{\n    display:none;\n}\n\n/* CARD */\n.service-card{\n    min-width:280px;\n    background:white;\n    border-radius:4px;\n    overflow:hidden;\n    box-shadow:0 2px 6px rgba(0,0,0,0.15);\n\n    scroll-snap-align:start;\n    flex-shrink:0;\n}\n\n.service-card img{\n    width:100%;\n    height:180px;\n    object-fit:cover;\n    display:block;\n}\n\n.service-content{\n    padding:18px;\n}\n\n.service-content h3{\n    margin:0;\n    font-size:20px;\n    font-weight:500;\n}\n\n/* ARROWS */\n.scroll-btn{\n    position:absolute;\n    top:55%;\n    transform:translateY(-50%);\n    width:45px;\n    height:45px;\n    border:none;\n    border-radius:50%;\n    background:white;\n    box-shadow:0 2px 6px rgba(0,0,0,0.25);\n    cursor:pointer;\n    z-index:5;\n    font-size:24px;\n}\n\n.scroll-btn:hover{\n    background:#eee;\n}\n\n.scroll-left{\n    left:-20px;\n}\n\n.scroll-right{\n    right:-20px;\n}\n\n/* MOBILE */\n@media (max-width:768px){\n\n    body{\n        margin:20px;\n    }\n\n    .services-title{\n        font-size:32px;\n    }\n\n    .service-card{\n        min-width:240px;\n    }\n\n    .scroll-btn{\n        display:none;\n    }\n}\n\n</style>\n</head>\n<body>\n\n<div class=\"services-wrapper\">\n\n    <h1 class=\"services-title\">Harbor Light Center Services</h1>\n\n    <button class=\"scroll-btn scroll-left\" onclick=\"scrollServices(-320)\">\n        ‹\n    </button>\n\n    <button class=\"scroll-btn scroll-right\" onclick=\"scrollServices(320)\">\n        ›\n    </button>\n\n    <div class=\"services-container\" id=\"servicesContainer\">\n\n        <div class=\"service-card\">\n            <img src=\"https://upload.wikimedia.org/wikipedia/commons/5/5c/Salvation_Army.svg\" alt=\"\">\n            <div class=\"service-content\">\n                <h3>Etc.</h3>\n            </div>\n        </div>\n\n        <div class=\"service-card\">\n            <img src=\"https://upload.wikimedia.org/wikipedia/commons/5/5c/Salvation_Army.svg\" alt=\"\">\n            <div class=\"service-content\">\n                <h3>Pastoral Care</h3>\n            </div>\n        </div>\n\n        <div class=\"service-card\">\n            <img src=\"https://upload.wikimedia.org/wikipedia/commons/5/5c/Salvation_Army.svg\" alt=\"\">\n            <div class=\"service-content\">\n                <h3>Housing Case Management</h3>\n            </div>\n        </div>\n\n        <div class=\"service-card\">\n            <img src=\"https://upload.wikimedia.org/wikipedia/commons/5/5c/Salvation_Army.svg\" alt=\"\">\n            <div class=\"service-content\">\n                <h3>Showers</h3>\n            </div>\n        </div>\n\n        <div class=\"service-card\">\n            <img src=\"https://upload.wikimedia.org/wikipedia/commons/5/5c/Salvation_Army.svg\" alt=\"\">\n            <div class=\"service-content\">\n                <h3>Meals</h3>\n            </div>\n        </div>\n\n        <div class=\"service-card\">\n            <img src=\"https://upload.wikimedia.org/wikipedia/commons/5/5c/Salvation_Army.svg\" alt=\"\">\n            <div class=\"service-content\">\n                <h3>Shelter</h3>\n            </div>\n        </div>\n\n        <div class=\"service-card\">\n            <img src=\"https://upload.wikimedia.org/wikipedia/commons/5/5c/Salvation_Army.svg\" alt=\"\">\n            <div class=\"service-content\">\n                <h3>Recovery Programs</h3>\n            </div>\n        </div>\n\n    </div>\n\n</div>\n\n<script>\n\nfunction scrollServices(scrollAmount){\n    const container = document.getElementById('servicesContainer');\n\n    container.scrollBy({\n        left: scrollAmount,\n        behavior: 'smooth'\n    });\n}\n\n</script>\n\n</body>\n</html>"},"6-98dac4fd85-s1lt65:1780512304213:0.4168204043058469":{"model":"6-98dac4fd85-s1lt65","name":"Generic Image Text Button Block","type":"block","html":"{{block('/-/block/generic_image_text_button_block.html?variant=7-de9687decb-zzt4tw&version=2')}}","description":"","draggable":true,"content":"{{block('/-/block/generic_image_text_button_block.html?variant=7-de9687decb-zzt4tw&version=2')}}","position":3,"fullName":"6-98dac4fd85-s1lt65:1780512304213:0.4168204043058469","primarytype":"content","newLoc":"layout:root:column:0","oldLoc":"layout:root:column:0","id":"6-98dac4fd85-s1lt65:1780512304213:0.4168204043058469"}}}}