<div
  class="bg-light rounded-5 position-absolute w-100 d-flex flex-column"
  id="header-donate-drawer"
>
  <div class="services-filter__header position-relative px-sm-9 px-md-14 pt-sm-5 py-md-7">
    <button id="donate-close-btn" class="d-flex align-items-center justify-content-center btn btn-sm p-0 position-absolute top-5 end-5">
      <span class="material-symbols-outlined text-dark-50 fs-5"> close </span>
    </button>
    <div class="row">
      <div class="goods-wrapper col-12 col-md-6 pe-md-8 order-2 order-md-1 mt-7 mt-md-0">
        <div class="border-bottom border-dark-50">
          <h6 class="fs-7">Donate Goods</h6>
        </div>
        <div class="pt-6">
          <form action="" id="donate-goods-form">
            <div class="row form-row g-0">
              <div class="col d-flex">
                <div class="input-group">
                  <span class="material-symbols-outlined input-group-text text-dark-50">
                    location_on
                  </span>
                  <input type="text" class="form-control pac-target-input ps-0" id="donate-goods-zip" placeholder="Enter 5 Digit ZIP Code" autocomplete="off">
                </div>
              </div>
              <div class="col-auto ps-2">
                <button type="submit" id="btn-submit" class="mt-auto btn btn-primary btn-md w-100" data-location-type="nav-top:donation-drawer-goods" data-function-type="other" data-format-type="button" data-link-type="external">
                  GO
                </button>
              </div>
            </div>
          </form>
          <div class="pt-sm-4 pt-md-5">
            <p>Enter your ZIP code to continue to our donation site to find local donation options for clothing, furniture, and more.</p>
          </div>
        </div>
      </div>
      <div class="donate-wrapper col-12 col-md-6 ps-md-8 order-1 order-md-2">
        <div class="donate-header mt-sm-6 mt-md-0 pb-3 mb-md-3">
          <h6 class="fs-7 mb-0 me-3 pe-3">Give Now</h6>
        </div>
        <div class="pt-3 amount-messages">
          <p>Your donation helps spread joy by providing meals, shelter, and support for your local neighbors in need.</p>
        </div>
        <div class="row pt-lg-6">
          <div class="col-12 donate-locally">
            <a href="#" id="drawer-donate-once" class="mt-auto btn btn-primary btn-lg w-sm-100 w-md-auto me-lg-2" data-location-type="nav-top:donation-drawer-donate-once" data-function-type="other" data-format-type="button" data-link-type="external">Donate Once</a>
            <a href="#" id="drawer-donate-monthly" class="mt-4 mt-md-auto btn btn-secondary btn-lg w-sm-100 w-md-auto" data-location-type="nav-top:donation-drawer-donate-monthly" data-function-type="other" data-format-type="button" data-link-type="external">Donate Monthly</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
  document.addEventListener("DOMContentLoaded", function () {
    var donationDrawer = document.getElementById('header-donate-drawer');

    if (!donationDrawer) {
      return;
    }

    var donateHeaderButtons = document.querySelectorAll('button.header-donate-button');

    function setDonateButtonState(isActive) {
      donateHeaderButtons.forEach(function(btn) {
        btn.classList.toggle('dropdown-active', isActive);
        btn.classList.toggle('dropdown-ready', !isActive);

        var icon = btn.querySelector('i');
        if (icon) {
          icon.classList.toggle('bi-chevron-up', isActive);
          icon.classList.toggle('bi-chevron-down', !isActive);
        }
      });
    }

    window.forceOpenDonationDrawer = function() {
      donationDrawer.classList.remove('hide');
      donationDrawer.classList.add('active');
      setDonateButtonState(true);
    };

    window.forceCloseDonationDrawer = function() {
      donationDrawer.classList.add('hide');
      donationDrawer.classList.remove('active');
      setDonateButtonState(false);
    };

    function closeHeaderChrome() {
      var navMenuElement = typeof navMenu !== 'undefined' ? navMenu : null;
      var searchContainerElement = document.getElementById('header-search-container');
      var searchToggleButton = document.getElementById('search-toggle-btn');
      var findHelpElement = document.getElementById('header-help-container');

      if (navMenuElement) {
        navMenuElement.style.transform = 'unset';
        navMenuElement.classList.remove('active');
      }

      if (searchContainerElement && searchContainerElement.classList.contains('active')) {
        searchContainerElement.classList.remove('active');

        var searchIcon = searchToggleButton ? searchToggleButton.querySelector('span') : null;
        if (searchIcon) {
          searchIcon.classList.toggle('text-primary-200');
          searchIcon.classList.toggle('text-dark-100');
        }
      }

      document.querySelectorAll('.header-dropdown').forEach(function(dropdown) {
        dropdown.classList.remove('show');
        if (dropdown.nextElementSibling) {
          dropdown.nextElementSibling.classList.remove('show');
        }
      });

      if (findHelpElement) {
        findHelpElement.classList.remove('active');
      }
    }

    window.toggleHeaderDonationDrawer = function(event, button, options) {
      if (event) {
        event.preventDefault();
        event.stopImmediatePropagation();
      }

      if (options && options.trackClick && typeof LinkTrackingClickEvent === 'function') {
        LinkTrackingClickEvent(button, 'donate_money_click');
      }

      closeHeaderChrome();

      if (donationDrawer.classList.contains('active')) {
        window.forceCloseDonationDrawer();
      } else {
        window.forceOpenDonationDrawer();
      }
    };

    document.addEventListener('click', function(event) {
      var donateButton = event.target.closest('.header-donate-button');

      if (!donateButton || donationDrawer.contains(donateButton)) {
        return;
      }

      window.toggleHeaderDonationDrawer(event, donateButton, { trackClick: true });
    }, true);

    var donationCloseBtn = donationDrawer.querySelector('#donate-close-btn');
    if (donationCloseBtn) {
      donationCloseBtn.addEventListener('click', function () {
        window.forceCloseDonationDrawer();
      });
    }

    var donateGoodsForm = donationDrawer.querySelector('#donate-goods-form');
    var zipInput = donationDrawer.querySelector('#donate-goods-zip');
    var goButton = donationDrawer.querySelector('#btn-submit');

    if (donateGoodsForm && zipInput && goButton) {
      goButton.disabled = true;
      goButton.classList.add('disabled');

      function isValidZipCode(zip) {
        return /^\d{5}$/.test(zip);
      }

      function updateButtonState() {
        var zipValue = zipInput.value.trim();
        goButton.disabled = !isValidZipCode(zipValue);
        goButton.classList.toggle('disabled', goButton.disabled);
      }

      zipInput.addEventListener('input', updateButtonState);
      zipInput.addEventListener('keyup', updateButtonState);

      donateGoodsForm.addEventListener('submit', function(e) {
        e.preventDefault();

        if (!isValidZipCode(zipInput.value.trim())) {
          return;
        }

        var zipCode = zipInput.value.trim();
        var donateURL = 'https://satruck.org/Donate/Choose?zip=' + encodeURIComponent(zipCode);

        if (typeof utag !== 'undefined' && utag.link) {
          utag.link({
            event: 'donate_goods_click',
            link_function: 'donation',
            link_format: 'button',
            link_text: 'Go',
            link_location: 'donation drawer',
            link_url: 'https://satruck.org/Donate/Choose',
            link_type: 'internal',
          });
        }

        window.location.href = donateURL;
      });
    }

    function getCookieValue(keyName, fallback) {
      if (typeof cookieManager === 'undefined' || typeof cookieKeys === 'undefined' || !cookieKeys[keyName]) {
        return fallback;
      }

      return cookieManager.get(cookieKeys[keyName]) || fallback;
    }

    function buildDonationUrl(frequency) {
      var classyURL = getCookieValue('classyCampaignURL', '{{homepage.first().classy_url}}');
      var campaignID = frequency === 'monthly' ? '680817' : '676125';
      var baseUrl = classyURL;

      try {
        var parsedClassyURL = new URL(classyURL, window.location.origin);
        baseUrl = parsedClassyURL.origin + '/campaign/' + campaignID + '/donate';
      } catch (error) {
        baseUrl = classyURL.replace(/\/campaign\/[^\/]+\/donate.*|\/checkout.*|\/$/, '') + '/campaign/' + campaignID + '/donate';
      }

      var params = [
        'c_src=NT26TZOAEC',
        'c_src2=' + encodeURIComponent(frequency === 'monthly' ? 'HeaderDonateBtn_Monthly' : 'HeaderDonateBtn_GiveOnce')
      ];

      return baseUrl + (baseUrl.indexOf('?') === -1 ? '?' : '&') + params.join('&');
    }

    var onceUrl = buildDonationUrl('one-time');
    var monthlyUrl = buildDonationUrl('monthly');
    var onceBtn = donationDrawer.querySelector('#drawer-donate-once');
    var monthlyBtn = donationDrawer.querySelector('#drawer-donate-monthly');

    function bindDonationButton(button, url, linkText) {
      if (!button || !url) {
        return;
      }

      button.href = url;
      button.target = '_blank';
      button.rel = 'noopener noreferrer';
      button.addEventListener('click', function() {
        if (typeof utag !== 'undefined' && utag.link) {
          utag.link({
            event: 'donate_money_click',
            link_function: 'donation',
            link_format: 'button',
            link_text: linkText,
            link_location: 'donation drawer',
            link_url: url,
            link_type: 'external',
          });
        }
      });
    }

    bindDonationButton(onceBtn, onceUrl, 'donate once');
    bindDonationButton(monthlyBtn, monthlyUrl, 'donate monthly');
  });
</script>
